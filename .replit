modules = ["python-3.11", "java-graalvm22.3"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["freetype", "glibcLocales", "lcms2", "libGL", "libGLU", "libimagequant", "libjpeg", "libtiff", "libwebp", "libxcrypt", "openjpeg", "proj", "tcl", "tk", "zlib"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "DJI SDK Development"

[[workflows.workflow]]
name = "DJI SDK Development"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd processing && python -m dji_photogrammetry.cli --help"

[workflows.workflow.metadata]
outputType = "console"
