<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="?attr/colorPrimary"
            app:title="Route Follow Mode"
            app:titleTextColor="@android:color/white"/>
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Route waypoints card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp">
                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">

                    <TextView android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Route Waypoints"
                        android:textStyle="bold" android:textSize="15sp"
                        android:textColor="?attr/colorPrimary"
                        android:layout_marginBottom="8dp"/>

                    <TextView android:id="@+id/tvRouteSummary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:layout_marginBottom="8dp"
                        android:text=""/>

                    <TextView android:id="@+id/tvWaypoints"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace"
                        android:textSize="12sp"
                        android:lineSpacingMultiplier="1.5"
                        android:layout_marginBottom="12dp"
                        android:text=""/>

                    <!-- Row 1: Add + Clear -->
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnAddWaypoint"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            android:text="+ Add Waypoint"
                            app:cornerRadius="8dp"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnClearWaypoints"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Clear All"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            app:cornerRadius="8dp"/>

                    </LinearLayout>

                    <!-- Row 2: Import KML / KMZ (full width) -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnImportKml"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Import KML / KMZ as Waypoints"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        app:cornerRadius="8dp"
                        app:icon="@android:drawable/ic_menu_upload"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Settings card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp">
                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">

                    <TextView android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Settings"
                        android:textStyle="bold" android:textSize="15sp"
                        android:textColor="?attr/colorPrimary"
                        android:layout_marginBottom="12dp"/>

                    <!-- Pace Speed -->
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="4dp">
                        <TextView android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Pace Speed" android:textSize="13sp"/>
                        <TextView android:id="@+id/tvSpeedVal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textStyle="bold" android:textSize="13sp"
                            android:text="5 m/s"/>
                    </LinearLayout>
                    <SeekBar android:id="@+id/seekRouteSpeed"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:max="14"
                        android:layout_marginBottom="16dp"/>

                    <!-- Drone Altitude -->
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="4dp">
                        <TextView android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Drone Altitude (AGL)" android:textSize="13sp"/>
                        <TextView android:id="@+id/tvAltitudeVal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textStyle="bold" android:textSize="13sp"
                            android:text="30 m"/>
                    </LinearLayout>
                    <SeekBar android:id="@+id/seekAltitude"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:max="58"
                        android:layout_marginBottom="4dp"/>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Applies to new waypoints and KML imports. Use 'Apply to All' to update existing waypoints."
                        android:textSize="11sp"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:layout_marginBottom="8dp"/>
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnApplyAltitude"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Apply to All Waypoints"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        app:cornerRadius="8dp"
                        android:layout_marginBottom="16dp"/>

                    <!-- Fly Backwards -->
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">
                        <TextView android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Fly Backwards" android:textSize="13sp"/>
                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switchBackwards"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                    </LinearLayout>

                    <!-- Update Home -->
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Update Home at End" android:textSize="13sp"/>
                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switchUpdateHome"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnExportRoute"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="12dp"
                android:text="Export Route JSON"
                android:textSize="15sp"
                app:cornerRadius="12dp"/>

            <!-- Export preview -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardExport"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                android:visibility="gone">
                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">
                    <TextView android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Route JSON"
                        android:textStyle="bold" android:textSize="14sp"
                        android:layout_marginBottom="8dp"/>
                    <TextView android:id="@+id/tvRouteJson"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace"
                        android:textSize="11sp"
                        android:text=""/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
